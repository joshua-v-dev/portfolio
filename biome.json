{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "src/**",
      "*.ts",
      "*.mjs",
      "*.json",
      "!additional.d.ts",
      "vitest.config.ts",
      "biome.json",
      "tsconfig.json",
      "package.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "linter": {
    "enabled": true,
    "includes": ["src/**", "vitest.config.ts", "next.config.mjs"],
    "rules": {
      "recommended": true,
      "a11y": {
        "noSvgWithoutTitle": "off",
        "useValidAnchor": "off",
        "noRedundantRoles": "off",
        "useAnchorContent": "off",
        "useButtonType": "off",
        "useSemanticElements": "off",
        "useKeyWithClickEvents": "off",
        "noInteractiveElementToNoninteractiveRole": "off",
        "noStaticElementInteractions": "off",
        "useAltText": "off"
      },
      "correctness": {
        "noUnusedImports": "warn",
        "noEmptyPattern": "warn"
      },
      "performance": {
        "noImgElement": "off"
      },
      "complexity": {
        "noUselessFragments": "warn"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useNodejsImportProtocol": "warn",
        "noDescendingSpecificity": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noArrayIndexKey": "off",
        "noUnknownAtRules": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "css": {
    "formatter": {
      "quoteStyle": "double"
    },
    "parser": {
      "cssModules": false,
      "tailwindDirectives": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
